{
  "manifest_version": 3,
  "name": "JioHotstar Auto Skip",
  "version": "1.0",
  "description": "Auto-skip intros and bypass long mid-roll ad breaks on JioHotstar.",
  "permissions": ["storage", "debugger"],
  "host_permissions": ["*://*.hotstar.com/*", "*://*.jiohotstar.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.hotstar.com/*", "*://*.jiohotstar.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
